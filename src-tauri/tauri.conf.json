{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "桌面小怪兽",
  "version": "0.1.0",
  "identifier": "com.jasmine.desktop-pet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "桌面小怪兽",
        "width": 260,
        "height": 260,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "一个低存在感但有灵性的桌面小怪兽",
    "longDescription": "一个会根据工作状态改变心情的 Windows 桌面小怪兽。"
  }
}
